{
    "name":  "cabal-legacy",
    "private":  true,
    "version":  "0.1.0",
    "scripts":  {
                    "dev":  "next dev",
                    "prebuild":  "node scripts/prepare-build.mjs",
                    "build":  "node scripts/build-e2e-bundle.mjs --dist=.next",
                    "start":  "next start",
                    "lint":  "eslint . --max-warnings=0",
                    "typecheck":  "tsc --noEmit",
                    "reset:data":  "node scripts/reset-local-state.mjs",
                    "pretest:unit":  "node scripts/reset-local-state.mjs",
                    "test:unit":  "vitest run",
                    "test:unit:watch":  "vitest",
                    "posttest:unit":  "node scripts/reset-local-state.mjs",
                    "pretest:smoke":  "node scripts/reset-local-state.mjs \u0026\u0026 node scripts/build-e2e-bundle.mjs",
                    "test:smoke":  "node scripts/run-playwright.mjs tests/e2e/home.smoke.spec.ts",
                    "posttest:smoke":  "node scripts/reset-local-state.mjs \u0026\u0026 node scripts/cleanup-generated-state.mjs",
                    "pretest:e2e":  "node scripts/reset-local-state.mjs \u0026\u0026 node scripts/build-e2e-bundle.mjs",
                    "test:e2e":  "node scripts/run-playwright.mjs",
                    "posttest:e2e":  "node scripts/reset-local-state.mjs \u0026\u0026 node scripts/cleanup-generated-state.mjs",
                    "test:e2e:headed":  "node scripts/run-playwright.mjs --headed",
                    "cleanup:generated":  "node scripts/cleanup-generated-state.mjs --with-build",
                    "verify:final":  "node scripts/verify-final.mjs"
                },
    "dependencies":  {
                         "class-variance-authority":  "^0.7.1",
                         "clsx":  "^2.1.1",
                         "lucide-react":  "^0.475.0",
                         "next":  "^15.2.0",
                         "react":  "^19.0.0",
                         "react-dom":  "^19.0.0",
                         "tailwind-merge":  "^3.0.2",
                         "tailwindcss-animate":  "^1.0.7",
                         "zod":  "^3.24.2"
                     },
    "devDependencies":  {
                            "@eslint/js":  "^9.19.0",
                            "@playwright/test":  "^1.58.2",
                            "@types/node":  "^22.13.5",
                            "@types/react":  "^19.0.2",
                            "@types/react-dom":  "^19.0.2",
                            "autoprefixer":  "^10.4.20",
                            "eslint":  "^9.19.0",
                            "eslint-config-next":  "^16.1.6",
                            "globals":  "^15.14.0",
                            "postcss":  "^8.5.3",
                            "tailwindcss":  "^3.4.17",
                            "typescript":  "^5.8.2",
                            "typescript-eslint":  "^8.22.0",
                            "vitest":  "^3.2.4"
                        },
    "packageManager":  "pnpm@10.32.1"
}
